        <mxCell id="guidance" value="Typical pattern: combine Option A for inbound private access with Option B or C for agent outbound control. Add Option D when you need a policy perimeter across Azure services." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;strokeWidth=2;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;fontColor=#334155;arcSize=8;" parent="1" vertex="1">
