        <mxCell id="private-link-card" value="&lt;b&gt;Option A: Private Link&lt;/b&gt;&lt;br&gt;GA&lt;br&gt;&lt;br&gt;Private endpoint for portal and Foundry APIs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;strokeWidth=2;fontSize=15;align=center;verticalAlign=middle;fontColor=#111827;arcSize=8;" parent="1" vertex="1">
