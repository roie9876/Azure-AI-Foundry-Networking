# =============================================================================
# SharePoint Sync Pipeline Configuration
# =============================================================================
# Copy this file to sharepoint-sync.env and fill in your values.
# Script: 3-deploy-sharepoint-sync.sh
#
# Prerequisites:
#   - Hub + Spoke deployed (1-deploy-hub.sh, 2-deploy-spoke.sh)
#   - Foundry deployed via Bicep (see README Part 13, Step 3)
#   - App Registration (SPN) with Sites.Read.All or Sites.Selected + Files.Read.All
#
# SENSITIVE FILE – DO NOT COMMIT TO GIT (already in .gitignore)
# =============================================================================

# ==========================
# Azure Subscription / Networking
# ==========================
SUBSCRIPTION_ID=<your-subscription-id>
LOCATION=swedencentral

# Spoke resources (must match spoke.env / Foundry deployment)
SPOKE_RG=foundry-spoke-rg
SPOKE_VNET_NAME=spoke-vnet

# Hub resources (must match hub.env)
# NOTE: HUB_RG is only required when FW_MODE=azure (see below).
#       For FW_MODE=external (3rd-party firewall) you can leave it blank.
HUB_RG=foundry-hub-rg
FW_PRIVATE_IP=10.0.1.4

# Subnet prefix for the Function App (must be unused in your spoke VNet)
FUNC_SUBNET_PREFIX=10.230.4.0/24

# Spoke VNet address space (used for firewall rules)
SPOKE_ADDRESS_SPACE=10.230.0.0/16

# ==========================
# Customer Environment Overrides (optional — all auto-discovered if unset)
# ==========================
# The script's Step 0 auto-discovers UDR, PE subnet, DNS zone RGs, and FW
# policy. Set any of these ONLY if you want to override discovery or if
# auto-discovery fails in your environment.
#
# UDR_NAME           Name of the route table that sends 0.0.0.0/0 → firewall.
#                    Auto-discovered from an existing spoke subnet.
# SPOKE_PE_SUBNET_NAME  Subnet in the spoke VNet used for private endpoints.
#                    Default: pe-subnet
# DNS_SUBSCRIPTION   Subscription ID where private DNS zones live. In many
#                    enterprises zones are centralized in a connectivity/hub
#                    subscription separate from the workload subscription.
#                    Default: SUBSCRIPTION_ID (same subscription)
# DNS_ZONE_RG        Resource group where AUTO-CREATED private DNS zones
#                    (privatelink.queue/table.core.windows.net) are placed.
#                    Enterprise customers centralize all privatelink.* zones
#                    in a single hub/connectivity RG — set this to that RG
#                    (combined with DNS_SUBSCRIPTION) so the zones created
#                    by this script follow the same DNS governance.
#                    Default: SPOKE_RG (workload-local)
#
# FW_MODE            'azure'    → apply rules to the Azure Firewall policy (default)
#                    'external' → skip Azure FW steps (use with 3rd-party NVAs
#                                 e.g. Fortinet, Palo Alto, Check Point).
#                                 The script will print the FQDNs you must
#                                 allow manually on your firewall.
# FW_POLICY_NAME     Azure Firewall policy name (only used if FW_MODE=azure).
#                    Default: hub-fw-policy
# FW_POLICY_RG       RG that contains the FW policy. Default: HUB_RG
# FW_RCG_NAME        Rule collection group. Default: DefaultAppRuleGroup
# FW_RCG_PRIORITY    RCG priority. Default: 300
#
# SEARCH_ACCESS_MODE How the script talks to AI Search data plane to create
#                    index/datasource/skillset/indexer.
#                    'toggle-public' (default) — briefly flips public access
#                      on/off. Simple, but FAILS if Azure Policy denies
#                      publicNetworkAccess changes (common in customer envs).
#                    'private' — never touches public access. Requires you
#                      to run this script from inside the spoke VNet (VPN,
#                      bastion/jumpbox, or a self-hosted CI runner) so the
#                      Search private endpoint resolves.
# ==========================
#UDR_NAME=
#SPOKE_PE_SUBNET_NAME=pe-subnet
#DNS_SUBSCRIPTION=
#DNS_ZONE_RG=
#FW_MODE=azure
#FW_POLICY_NAME=hub-fw-policy
#FW_POLICY_RG=
#FW_RCG_NAME=DefaultAppRuleGroup
#FW_RCG_PRIORITY=300
#SEARCH_ACCESS_MODE=toggle-public

# ==========================
# Authentication (App Registration / SPN)
# ==========================
# These are stored in Key Vault by the deploy script.
# The Function App reads them via @Microsoft.KeyVault(...) references.
AZURE_CLIENT_ID=<your-app-registration-client-id>
AZURE_CLIENT_SECRET=<your-app-registration-client-secret>
AZURE_TENANT_ID=<your-tenant-id>

# ==========================
# SharePoint Configuration
# ==========================
SHAREPOINT_SITE_URL=https://contoso.sharepoint.com/sites/MySite
SHAREPOINT_DRIVE_NAME=Shared Documents
SHAREPOINT_FOLDER_PATH=/
# Comma-separated folder paths to sync. Use / for all, or e.g. /HR,/ENG for specific folders

# Optional file-extension filters (comma-separated, case-insensitive).
# Accepts ".pdf", "pdf", or "*.pdf" syntax. Leave blank for no filter.
# If INCLUDE is set, ONLY matching files are synced. EXCLUDE always removes matches.
# Examples: SHAREPOINT_INCLUDE_EXTENSIONS=.pdf,.docx,.pptx
#           SHAREPOINT_EXCLUDE_EXTENSIONS=*.zip,*.exe,*.tmp
SHAREPOINT_INCLUDE_EXTENSIONS=
SHAREPOINT_EXCLUDE_EXTENSIONS=

# ==========================
# Azure Blob Storage (existing, from Foundry deployment)
# ==========================
AZURE_STORAGE_ACCOUNT_NAME=<your-foundry-storage-account>
AZURE_BLOB_CONTAINER_NAME=sharepoint-sync
AZURE_BLOB_PREFIX=

# ==========================
# Sync Settings
# ==========================
# DELETE_ORPHANED_BLOBS — when true, blobs that no longer have a matching
# SharePoint source are processed as deletions on every sync run.
DELETE_ORPHANED_BLOBS=true
# SOFT_DELETE_ORPHANED_BLOBS (default: true) — when true, orphan/deletion
# handling sets blob metadata IsDeleted=true instead of issuing a permanent
# HTTP DELETE. The AI Search indexer's softDeleteColumnDeletionDetectionPolicy
# (softDeleteColumnName=IsDeleted) then removes all chunks projected from the
# blob on its next run. Benefits: blobs stay recoverable (audit trail), and
# fat-finger config mistakes (e.g. wrong SHAREPOINT_FOLDER_PATH) don't
# permanently nuke data. Set to false ONLY if you want hard deletes (legacy
# behaviour) — note: hard deletes leave stale chunks in the index because the
# indexer can't see a missing blob's metadata.
SOFT_DELETE_ORPHANED_BLOBS=true
DRY_RUN=false
SYNC_PERMISSIONS=true
PERMISSIONS_DELTA_MODE=hash
# Options: hash (SHA256, simpler) or graph_delta (Graph delta API, more efficient)

# ==========================
# Sync Schedules — how often the Function App runs sync jobs
# ==========================
# Format: NCRONTAB with 6 fields  ->  "second minute hour day month day-of-week"
# Use "*" for "every" and "*/N" for "every N units".
#
# Common examples (copy-paste ready):
#   Every 5 minutes ............... 0 */5  * * * *
#   Every 10 minutes .............. 0 */10 * * * *
#   Every 30 minutes .............. 0 */30 * * * *
#   Every hour (on the hour) ...... 0 0    * * * *
#   Every 6 hours ................. 0 0    */6 * * *
#   Daily at 03:00 UTC ............ 0 0    3 * * *
#   Weekly on Sunday 02:00 UTC .... 0 0    2 * * 0
#
# ─── DELTA SYNC (fast / incremental) ───────────────────────────────────
# Only picks up files that CHANGED since last run. Cheap — run often.
TIMER_SCHEDULE="0 0 * * * *"

# ─── FULL RECONCILE (slow / complete) ──────────────────────────────────
# Lists EVERY file in scope, re-uploads what's missing, and DELETES
# orphan blobs from renames/moves (delta mode can't detect those).
# More expensive — run less often.
TIMER_SCHEDULE_FULL="0 0 3 * * *"

# ==========================
# Azure AI Search (existing, from Foundry deployment)
# ==========================
SEARCH_SERVICE_NAME=<your-ai-search-name>
SEARCH_RESOURCE_GROUP=<your-spoke-rg>
API_VERSION=2025-11-01

# Component names (created by this script)
INDEX_NAME=sharepoint-index
INDEXER_NAME=sharepoint-blob-indexer
SKILLSET_NAME=sharepoint-sync-skillset
DATASOURCE_NAME=sharepoint-blob-ds

# ==========================
# Azure OpenAI (for embeddings in skillset)
# ==========================
OPENAI_RESOURCE_URI=https://<your-ai-services>.cognitiveservices.azure.com/
EMBEDDING_DEPLOYMENT_ID=text-embedding-3-small
EMBEDDING_MODEL_NAME=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ==========================
# Purview Integration (optional)
# ==========================
SYNC_PURVIEW_PROTECTION=false

# ==========================
# Foundry Agent Configuration (Step 14)
# ==========================
# AI Services account name (for agent API endpoint)
AI_SERVICES_NAME=<your-ai-services-name>
# Foundry project name (sub-resource of AI Services)
FOUNDRY_PROJECT_NAME=<your-foundry-project-name>
# Agent name (created or updated by Step 14)
FOUNDRY_AGENT_NAME=sharepoint-search-agent
# Agent model deployment
FOUNDRY_AGENT_MODEL=gpt-4.1
# Agent instructions
FOUNDRY_AGENT_INSTRUCTIONS="Answer only from the knowledge-source.\nYou are not allowed to answer from the internet.\nIf you don't know the answer say I don't know.\n\nWhen citing sources, use the document URL from the search results."

# ==========================
# RAG Tuning (optional — all have sensible defaults)
# ==========================
# Changing any value in this section rebuilds index/skillset/indexer on the
# next deploy (Step 11 deletes + recreates these artifacts by design). Data
# is re-materialized on the next indexer run.
#
# --- Chunking (SplitSkill) ---
# CHUNK_SPLIT_MODE   pages | sentences                            (default: pages)
# CHUNK_UNIT         characters | azureOpenAITokens               (default: characters)
# CHUNK_SIZE         max length per chunk in the chosen unit      (default: 2000)
# CHUNK_OVERLAP      overlap between chunks in the chosen unit    (default: 200)
#CHUNK_SPLIT_MODE=pages
#CHUNK_UNIT=characters
#CHUNK_SIZE=2000
#CHUNK_OVERLAP=200

# --- Vector index (HNSW) ---
# VECTOR_METRIC           cosine | euclidean | dotProduct          (default: cosine)
# HNSW_M                  neighbors per node (4..10)               (default: 4)
# HNSW_EF_CONSTRUCTION    build-time search quality (100..1000)    (default: 400)
# HNSW_EF_SEARCH          query-time search quality (100..1000)    (default: 500)
# Higher M / ef values → better recall, larger index, slower builds.
#VECTOR_METRIC=cosine
#HNSW_M=4
#HNSW_EF_CONSTRUCTION=400
#HNSW_EF_SEARCH=500

# --- Semantic ranker (free quality bump, enabled by default) ---
# Disabling also forces AGENT_QUERY_TYPE away from semantic/vectorSemanticHybrid.
#SEMANTIC_CONFIG_ENABLED=true

# --- Indexer ---
# INDEXER_MAX_FAILED_ITEMS         -1 = unlimited (default)
# INDEXER_MAX_FAILED_PER_BATCH     -1 = unlimited (default)
# INDEXER_SCHEDULE_INTERVAL        ISO-8601 duration (default: PT1H)
#                                  examples: PT15M, PT30M, PT1H, P1D
#INDEXER_MAX_FAILED_ITEMS=-1
#INDEXER_MAX_FAILED_PER_BATCH=-1
#INDEXER_SCHEDULE_INTERVAL=PT1H

# --- Foundry agent azure_ai_search tool ---
# AGENT_QUERY_TYPE controls how the primary agent queries the index:
#   simple               keyword only (fastest, no vector recall)
#   semantic             keyword + semantic reranking (default — recommended)
#   vector               pure vector similarity
#   vectorSemanticHybrid keyword + vector + semantic reranker (best quality, highest latency)
# semantic/vectorSemanticHybrid require SEMANTIC_CONFIG_ENABLED=true.
#AGENT_QUERY_TYPE=semantic

# ==========================
# Agentic Retrieval (Knowledge Base via MCP) — Phase 3, opt-in
# ==========================
# When USE_AGENTIC_RETRIEVAL=true, Step 14b creates a second agent that uses
# AI Search agentic retrieval: the planner (AGENTIC_PLANNER_MODEL) decomposes
# the user question into multiple subqueries and fans them out to the KB.
# The primary agent (FOUNDRY_AGENT_NAME) is unchanged — both agents coexist
# so you can A/B compare them in the Foundry Playground.
#
# Resources created when enabled:
#   - Knowledge Source (AGENTIC_KS_NAME)  → wraps sharepoint-index
#   - Knowledge Base   (AGENTIC_KB_NAME)  → agentic retrieval endpoint
#   - Project connection (AGENTIC_PROJECT_CONN_NAME) → RemoteTool to KB MCP
#   - Foundry agent (AGENTIC_AGENT_NAME) → uses MCP tool
#
# AGENTIC_REASONING_EFFORT  minimal | low | medium  (default: low)
#     higher = more subqueries, higher latency + token cost
# AGENTIC_OUTPUT_MODE       extractiveData | answerSynthesis  (default: extractiveData)
#     extractiveData  → returns ranked passages (Foundry formats them)
#     answerSynthesis → KB returns a synthesized answer string
#USE_AGENTIC_RETRIEVAL=false
#AGENTIC_KS_NAME=sharepoint-ks
#AGENTIC_KB_NAME=sharepoint-kb
#AGENTIC_AGENT_NAME=sharepoint-agentic
#AGENTIC_PROJECT_CONN_NAME=sharepoint-kb-mcp
#AGENTIC_PLANNER_MODEL=gpt-4.1
#AGENTIC_REASONING_EFFORT=low
#AGENTIC_OUTPUT_MODE=extractiveData
#AGENTIC_AGENT_INSTRUCTIONS=

# ==========================
# Auto-populated by deploy script (do not set manually)
# ==========================
# After a successful run of 3-deploy-sharepoint-sync.sh, the following lines
# are appended (or refreshed) automatically inside a marker block at the
# bottom of sharepoint-sync.env so you can easily find the function trigger
# URL without re-running the deploy:
#
#   FUNC_APP_HOSTNAME=sp-sync-func-XXXXXX.azurewebsites.net
#   SYNC_CONSOLE_URL=https://sp-sync-func-XXXXXX.azurewebsites.net/api/sync?code=<master-key>
#
# Open SYNC_CONSOLE_URL in a browser to manually trigger the sync (delta or
# full reconcile, picked from the in-page menu). The block is delimited by
#   # >>> auto-populated by 3-deploy-sharepoint-sync.sh (do not edit) >>>
#   # <<< auto-populated by 3-deploy-sharepoint-sync.sh <<<
# and is rewritten on every deploy.
