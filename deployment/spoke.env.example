# =============================================================================
# Spoke Network Configuration
# =============================================================================
# Copy this file to spoke.env and fill in your values.
# Script: 2-deploy-spoke.sh
#
# Prerequisites: Hub must be deployed first (1-deploy-hub.sh)
# =============================================================================

# ==========================
# Azure Subscription
# ==========================
SUBSCRIPTION_ID=<your-subscription-id>
LOCATION=swedencentral

# ==========================
# Hub References (must match hub.env)
# ==========================
HUB_RG=foundry-hub-rg
HUB_VNET_NAME=hub-vnet
FW_POLICY_NAME=hub-fw-policy

# ==========================
# Spoke Resource Group
# ==========================
SPOKE_RG=foundry-spoke-rg

# ==========================
# Spoke VNet
# ==========================
SPOKE_VNET_NAME=spoke-vnet
SPOKE_VNET_PREFIX=10.100.0.0/16
SPOKE_VM_SUBNET_PREFIX=10.100.1.0/24        # Test VM
SPOKE_AGENT_SUBNET_PREFIX=10.100.3.0/24     # Foundry Agent Service (delegated)
SPOKE_PE_SUBNET_PREFIX=10.100.4.0/24        # Private Endpoints
SPOKE_BASTION_SUBNET_PREFIX=10.100.5.0/26   # Azure Bastion (min /26)

# ==========================
# Azure Bastion + Test VM
# ==========================
DEPLOY_BASTION=true                          # Set to false to skip Bastion+VM
BASTION_NAME=spoke-bastion
VM_NAME=test-vm
VM_SIZE=Standard_B2s
VM_ADMIN_USER=azureadmin
