# =============================================================================
# Hub Infrastructure Configuration
# =============================================================================
# Copy this file to hub.env and fill in your values.
# Script: 1-deploy-hub.sh
# =============================================================================

# ==========================
# Azure Subscription
# ==========================
SUBSCRIPTION_ID=<your-subscription-id>
LOCATION=swedencentral

# ==========================
# Resource Group
# ==========================
HUB_RG=foundry-hub-rg

# ==========================
# Hub VNet
# ==========================
HUB_VNET_NAME=hub-vnet
HUB_VNET_PREFIX=10.0.0.0/16
HUB_FW_SUBNET_PREFIX=10.0.1.0/26           # AzureFirewallSubnet (min /26)

# ==========================
# Azure Firewall
# ==========================
FW_NAME=hub-firewall
FW_POLICY_NAME=hub-fw-policy
FW_PIP_NAME=hub-fw-pip
FW_SKU=Standard                              # Standard or Basic

# ==========================
# Log Analytics
# ==========================
LAW_NAME=hub-fw-law
LAW_RETENTION_DAYS=30
