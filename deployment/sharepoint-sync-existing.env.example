# =============================================================================
# SharePoint Sync Pipeline Configuration — EXISTING ENVIRONMENT
# =============================================================================
# Copy this file to sharepoint-sync-existing.env and fill in your values.
# Script: 3-deploy-sharepoint-sync-existing-env.sh
#
# This variant assumes ALL infrastructure already exists:
#   - Hub + Spoke VNet, subnets, UDR, firewall
#   - Function App (Flex Consumption) with VNet integration
#   - Function App storage account with private endpoints
#   - Key Vault with private endpoint
#   - AI Search, AI Services / OpenAI
#   - Foundry storage account + blob container
#   - App Registration (SPN) with Sites.Read.All + Files.Read.All
#
# The script only does configuration and wiring:
#   - Stores SPN secrets in Key Vault
#   - Configures Function App settings (KV refs + AI Search + OpenAI)
#   - Grants RBAC (Function App → Storage/KV, AI Search → AI Services)
#   - Creates Shared Private Links (AI Search → Storage + AI Services)
#   - Creates AI Search artifacts (index, data source, skillset, indexer)
#   - Patches indexers to Private execution
#   - Adds firewall rules (Graph + SharePoint + Entra ID)
#   - Publishes sync code to Function App
#   - Configures Foundry Agent
#
# SENSITIVE FILE – DO NOT COMMIT TO GIT (already in .gitignore)
# =============================================================================

# ==========================
# Azure Subscription / Networking
# ==========================
SUBSCRIPTION_ID=<your-subscription-id>
LOCATION=swedencentral

# Spoke resources
SPOKE_RG=foundry-spoke-rg
SPOKE_VNET_NAME=spoke-vnet

# Hub resources (only required when FW_MODE=azure)
HUB_RG=foundry-hub-rg
FW_PRIVATE_IP=10.0.1.4

# Spoke VNet address space (used for firewall rules)
SPOKE_ADDRESS_SPACE=10.230.0.0/16

# ==========================
# EXISTING Infrastructure — Resource Names
# ==========================
# These resources MUST already exist. The script validates their presence
# at startup and fails fast if any are missing.

# Function App (.NET 10 isolated worker, system- or user-assigned identity).
# Linux. Flex Consumption / Elastic Premium / Consumption all supported.
# The deploy script builds with `dotnet publish` and uploads via SCM /api/publish.
FUNC_APP_NAME=<your-existing-function-app-name>

# Function App storage account (with blob/file/queue/table private endpoints)
# ⚠️  This is the INTERNAL storage used by the Function App runtime (triggers,
#     state, deployment packages). It is NOT the storage where SharePoint
#     documents land. See AZURE_STORAGE_ACCOUNT_NAME below for that.
FUNC_STORAGE_NAME=<your-existing-func-storage-account>

# Key Vault (RBAC-enabled, private endpoint)
KV_NAME=<your-existing-key-vault-name>

# Function subnet (delegated to Microsoft.App/environments, with UDR)
FUNC_SUBNET_NAME=func-subnet

# PE subnet in the spoke VNet (for private endpoint placement)
SPOKE_PE_SUBNET_NAME=pe-subnet

# ==========================
# Skip Toggles — for environments where networking is already fully managed
# ==========================
# Set to 'true' to skip steps that touch networking resources.
# Useful when the customer's network team owns firewall rules and/or
# shared private links were already created (e.g., via Bicep, Portal, or Terraform).
#
# SKIP_FIREWALL_RULES         Skip Step 7 (Azure Firewall application rules).
#                              Set to 'true' if the hub firewall is managed externally.
#                              The script will print the required FQDNs for reference.
#
# SKIP_SHARED_PRIVATE_LINKS   Skip Step 4 (AI Search → Storage/AI Services SPLs).
#                              Set to 'true' if SPLs were pre-created. The script
#                              assumes these already exist and are Approved:
#                                - AI Search → Storage (blob)
#                                - AI Search → AI Services (openai_account)
#                                - AI Search → AI Services (cognitiveservices_account)
#
# SKIP_DNS_VALIDATION          Skip DNS zone existence check in Step 0.
#                              Set to 'true' if DNS zones are in a subscription the
#                              operator can't list (common in centralized hub-spoke).
#                              The script does NOT create DNS records — this is only
#                              a sanity check. Alternatively, set DNS_SUBSCRIPTION
#                              to the subscription where DNS zones live.
#
# START_STEP                   Skip already-completed setup steps on re-runs.
#                              0 (default) = run everything from Step 1.
#                              Example: START_STEP=6 skips Steps 1-5 (KV secrets,
#                              app settings, RBAC, shared private links) and jumps
#                              straight to Step 6 (AI Search artifacts). Saves ~1-2
#                              minutes per iteration when debugging Step 6+ failures.
#                              Variable lookups (KV secret URIs, Search admin key)
#                              still run unconditionally so downstream steps work.
SKIP_FIREWALL_RULES=true
SKIP_SHARED_PRIVATE_LINKS=false
SKIP_DNS_VALIDATION=false
START_STEP=0

# ==========================
# Customer Environment Overrides (optional — all auto-discovered if unset)
# ==========================
# DNS_SUBSCRIPTION   Subscription where private DNS zones live. Default: SUBSCRIPTION_ID
# DNS_ZONE_RG        RG for auto-created DNS zones. Default: SPOKE_RG
# FW_MODE            'azure' (default) | 'external' (3rd-party NVA). Ignored when SKIP_FIREWALL_RULES=true.
# FW_POLICY_NAME     Azure Firewall policy name. Default: hub-fw-policy
# FW_POLICY_RG       RG containing FW policy. Default: HUB_RG
# SEARCH_ACCESS_MODE 'private' (default) | 'toggle-public'
#                    private        → run from inside the VNet (VPN/Bastion); never
#                                     touches AI Search public-access setting.
#                    toggle-public  → temporarily enables public access on AI Search
#                                     to hit the REST API from outside the VNet, then
#                                     re-disables it. Will prompt for confirmation.
#                                     NOT recommended for locked-down environments.
#DNS_SUBSCRIPTION=
#DNS_ZONE_RG=
#FW_MODE=azure
#FW_POLICY_NAME=hub-fw-policy
#FW_POLICY_RG=
#SEARCH_ACCESS_MODE=private

# ==========================
# Authentication (App Registration / SPN)
# ==========================
AZURE_CLIENT_ID=<your-app-registration-client-id>
AZURE_CLIENT_SECRET=<your-app-registration-client-secret>
AZURE_TENANT_ID=<your-tenant-id>

# ==========================
# SharePoint Configuration
# ==========================
SHAREPOINT_SITE_URL=https://contoso.sharepoint.com/sites/MySite
SHAREPOINT_DRIVE_NAME=Shared Documents
SHAREPOINT_FOLDER_PATH=/
SHAREPOINT_INCLUDE_EXTENSIONS=
SHAREPOINT_EXCLUDE_EXTENSIONS=

# ==========================
# Azure Blob Storage — DATA storage (existing, from Foundry deployment)
# ==========================
# ⚠️  This is the FOUNDRY storage account where SharePoint documents are synced
#     as blobs. The AI Search indexer reads from this storage account.
#     This is a DIFFERENT account from FUNC_STORAGE_NAME above, which is the
#     Function App's internal/runtime storage.
#
#  FUNC_STORAGE_NAME            → Function App runtime (triggers, packages)
#  AZURE_STORAGE_ACCOUNT_NAME   → SharePoint document blobs (AI Search reads here)
AZURE_STORAGE_ACCOUNT_NAME=<your-foundry-storage-account>
AZURE_BLOB_CONTAINER_NAME=sharepoint-sync
AZURE_BLOB_PREFIX=

# ==========================
# Sync Settings
# ==========================
DELETE_ORPHANED_BLOBS=true
SOFT_DELETE_ORPHANED_BLOBS=true
DRY_RUN=false
SYNC_PERMISSIONS=true
PERMISSIONS_DELTA_MODE=hash

# ==========================
# Sync Schedules
# ==========================
TIMER_SCHEDULE="0 0 * * * *"
TIMER_SCHEDULE_FULL="0 0 3 * * *"

# ==========================
# Azure AI Search (existing)
# ==========================
SEARCH_SERVICE_NAME=<your-ai-search-name>
API_VERSION=2025-11-01

# Search artifact names (created by this script inside the existing service)
INDEX_NAME=sharepoint-index
INDEXER_NAME=sharepoint-blob-indexer
SKILLSET_NAME=sharepoint-sync-skillset
DATASOURCE_NAME=sharepoint-blob-ds

# ==========================
# Azure OpenAI (for embeddings in skillset)
# ==========================
OPENAI_RESOURCE_URI=https://<your-ai-services>.cognitiveservices.azure.com/
EMBEDDING_DEPLOYMENT_ID=text-embedding-3-small
EMBEDDING_MODEL_NAME=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ==========================
# Purview Integration (optional)
# ==========================
SYNC_PURVIEW_PROTECTION=false

# ==========================
# Foundry Agent Configuration
# ==========================
AI_SERVICES_NAME=<your-ai-services-name>
FOUNDRY_PROJECT_NAME=<your-foundry-project-name>
FOUNDRY_AGENT_NAME=sharepoint-search-agent
FOUNDRY_AGENT_MODEL=gpt-4.1

# ==========================
# RAG Tuning (optional — all have sensible defaults)
# ==========================
#CHUNK_SPLIT_MODE=pages
#CHUNK_UNIT=characters
#CHUNK_SIZE=2000
#CHUNK_OVERLAP=200
#VECTOR_METRIC=cosine
#HNSW_M=4
#HNSW_EF_CONSTRUCTION=400
#HNSW_EF_SEARCH=500
#SEMANTIC_CONFIG_ENABLED=true
#INDEXER_MAX_FAILED_ITEMS=-1
#INDEXER_MAX_FAILED_PER_BATCH=-1
#INDEXER_SCHEDULE_INTERVAL=PT1H
#AGENT_QUERY_TYPE=semantic

# ==========================
# Agentic Retrieval (opt-in)
# ==========================
#USE_AGENTIC_RETRIEVAL=false
#AGENTIC_KS_NAME=sharepoint-ks
#AGENTIC_KB_NAME=sharepoint-kb
#AGENTIC_AGENT_NAME=sharepoint-agentic
#AGENTIC_PROJECT_CONN_NAME=sharepoint-kb-mcp
#AGENTIC_PLANNER_MODEL=gpt-4.1
#AGENTIC_REASONING_EFFORT=low
#AGENTIC_OUTPUT_MODE=extractiveData
